<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <meta name="title" content="Hindu Hostel, Prayagraj | Official Digital Portal">
    <meta name="description"
        content="The official digital platform for the historic Hindu Hostel (MacDonnell Boarding House), University of Allahabad. Heritage, Administration, and Student Services.">
    <meta name="keywords"
        content="Hindu Hostel, Prayagraj, Allahabad University, MacDonnell Boarding House, Student Portal, Hostel Management">
    <meta name="author" content="Shiv Mangal Singh">

    <meta property="og:type" content="website">
    <meta property="og:url" content="https://hindu-hostel.onrender.com/">
    <meta property="og:title" content="Hindu Hostel, Prayagraj | Heritage & Excellence">
    <meta property="og:description"
        content="Managing the legacy of 1901. Explore the official portal for residence and heritage.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://hindu-hostel.onrender.com/">
    <meta property="og:title" content="Hindu Hostel | Digital Portal">
    <meta property="og:description"
        content="Official digital archives and administrative desk for the residents of Hindu Hostel, Prayagraj.">

    <meta property="og:image" content="https://hindu-hostel.onrender.com/images/hindu-hostel.jpg">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="https://hindu-hostel.onrender.com/images/hindu-hostel.jpg">

    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content="Hindu Hostel, Prayagraj">
    <meta property="twitter:description"
        content="Digital portal for the University of Allahabad's most iconic residence.">

    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .font-roman {
            font-family: "Times New Roman", Times, serif;
        }

        body {
            font-variant-numeric: lining-nums;
            -moz-font-feature-settings: "lnum";
            -webkit-font-feature-settings: "lnum";
            font-feature-settings: "lnum";
        }

        .swiper-fade .swiper-slide {
            pointer-events: none;
            transition-property: opacity;
            z-index: 0;
        }

        .swiper-fade .swiper-slide-active {
            pointer-events: auto;
            z-index: 1;
        }

        .swiper-slide img {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        ::selection {
            background-color: #b91c1c;
            color: #ffffff;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #09090b;
        }

        ::-webkit-scrollbar-thumb {
            background: #27272a;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #b91c1c;
        }

        @media (max-width: 640px) {

            .swiper-button-next,
            .swiper-button-prev {
                display: none !important;
            }
        }

        .group:hover h3 {
            text-shadow: 0 0 10px rgba(185, 28, 28, 0.4);
            transition: all 0.3s ease;
        }
    </style>
</head>

<body class="min-h-screen flex flex-col">