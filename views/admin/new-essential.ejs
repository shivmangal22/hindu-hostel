<%- include('../partials/head') %>
    <%- include('../partials/nav') %>
        <%- include('../partials/flash') %>


            <main class="min-h-screen bg-zinc-950 text-stone-50 py-20 font-serif">
                <div class="max-w-3xl mx-auto px-6">
                    <header class="mb-12 border-b border-zinc-800 pb-8">
                        <div class="flex items-center gap-4 mb-2">
                            <h1 class="text-4xl italic tracking-tighter">Register Essential Service</h1>
                        </div>
                        <p class="text-red-600 font-bold tracking-[0.3em] text-[10px] uppercase mt-2 font-sans">
                            Local
                            Directory
                            Management</p>
                        <div class="flex items-center gap-2 mt-6">
                            <a href="javascript:void(0)" onclick="history.back()"
                                class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2">
                                <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                                <span>Back</span>
                            </a>
                        </div>
                    </header>
                    <form action="/admin/essentials/new" method="POST" class="space-y-8 font-sans">

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-emerald-600 mb-3">Service
                                    Name</label>
                                <input type="text" name="name" required placeholder="e.g. Apollo Pharmacy"
                                    class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-emerald-600 outline-none transition-all text-sm">
                            </div>
                            <div>
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-emerald-600 mb-3">Category</label>
                                <select name="category" required
                                    class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-emerald-600 outline-none transition-all text-sm text-zinc-400">
                                    <option value="Hospital">Hospital / Clinic</option>
                                    <option value="Pharmacy">Pharmacy</option>
                                    <option value="Stationery">Stationery & Print</option>
                                    <option value="General/Mess">General Store / Mess Supply</option>
                                    <option value="Other">Other Emergency</option>
                                </select>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="md:col-span-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-emerald-600 mb-3">Physical
                                    Address</label>
                                <input type="text" name="address" required placeholder="Street name, Landmark..."
                                    class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-emerald-600 outline-none transition-all text-sm">
                            </div>
                            <div>
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-emerald-600 mb-3">Distance</label>
                                <input type="text" name="distance" placeholder="e.g. 400m"
                                    class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-emerald-600 outline-none transition-all text-sm">
                            </div>
                        </div>

                        <div class="space-y-6 bg-zinc-900/30 p-6 rounded-2xl border border-zinc-900">
                            <h3 class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-4">Contact Channels
                            </h3>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="relative">
                                    <i class="ri-phone-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600"></i>
                                    <input type="text" name="phone" placeholder="Phone Number"
                                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-4 pl-12 focus:border-emerald-600 outline-none transition-all text-sm">
                                </div>
                                <div class="relative">
                                    <i
                                        class="ri-global-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600"></i>
                                    <input type="url" name="website" placeholder="Website URL (https://...)"
                                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-4 pl-12 focus:border-blue-600 outline-none transition-all text-sm">
                                </div>
                                <div class="relative">
                                    <i class="ri-mail-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600"></i>
                                    <input type="email" name="email" placeholder="Email Address"
                                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl p-4 pl-12 focus:border-red-600 outline-none transition-all text-sm">
                                </div>

                                <div class="flex items-center gap-4 px-2">
                                    <input type="checkbox" name="isOpen247" id="isOpen247" value="true"
                                        class="w-5 h-5 accent-emerald-600">
                                    <label for="isOpen247" class="text-sm text-zinc-400">Available 24/7</label>
                                </div>
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-emerald-700 hover:bg-emerald-600 text-white font-bold py-5 rounded-xl transition-all shadow-xl tracking-widest text-xs">
                            ADD TO DIRECTORY
                        </button>
                    </form>
                </div>
            </main>

            <%- include('../partials/footer') %>