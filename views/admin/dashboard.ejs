<%- include('../partials/head') %>
    <%- include('../partials/nav') %>
        <%- include('../partials/flash') %>

            <div id="adminModal" class="fixed inset-0 z-[150] hidden flex items-center justify-center p-4 pt-6">
                <div class="absolute inset-0 bg-black/90 backdrop-blur-md" onclick="toggleAdminModal()"></div>

                <div
                    class="relative bg-zinc-900 border border-zinc-800 w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">

                    <div class="p-8 border-b border-zinc-800 flex justify-between items-center bg-zinc-950/50">
                        <div>
                            <h3 class="text-white font-serif italic text-2xl">Staff Register</h3>
                            <p class="text-red-500 font-sans font-bold text-[10px] uppercase tracking-[0.3em]">Promote
                                Residents or
                                Manage
                                Privileges</p>
                        </div>
                        <button onclick="toggleAdminModal()"
                            class="w-10 h-10 rounded-full flex items-center justify-center bg-zinc-800 text-zinc-400 hover:text-white transition-all">
                            <i class="ri-close-line text-xl"></i>
                        </button>
                    </div>

                    <div class="p-6 bg-zinc-950/30 border-b border-zinc-800">
                        <div class="flex justify-center items-center">
                            <a href="/admin/manage-admins"
                                class="w-fit px-6 block py-4 rounded-xl bg-red-700 hover:bg-red-600 text-white transition-all text-center font-bold text-[10px] uppercase tracking-widest"
                                target="_parent">
                                Manage Administrative Staff <i class="ri-arrow-right-line"></i>
                            </a>
                        </div>
                    </div>

                    <div class="overflow-y-auto p-6 space-y-4">
                        <p class="text-[9px] font-black text-zinc-500 uppercase tracking-[0.2em] mb-2">Active
                            Administrative Staff
                        </p>

                        <% allAdmins.forEach(adm=> { %>
                            <div
                                class="flex items-center justify-between p-5 bg-zinc-950/50 border border-zinc-800 rounded-2xl group hover:border-red-900/50 transition-all">
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-10 h-10 rounded-lg bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-600 group-hover:text-red-500 transition-colors">
                                        <i class="ri-shield-user-line text-xl"></i>
                                    </div>
                                    <div>
                                        <p class="text-white font-bold text-sm flex items-center gap-2">
                                            <%= adm.name %>
                                                <span
                                                    class="text-[8px] px-2 py-0.5 rounded bg-red-900/20 text-red-400 border border-red-900/50 uppercase tracking-tighter font-black">
                                                    <%= adm.role %>
                                                </span>
                                        </p>
                                        <p class="text-zinc-500 text-[11px] font-mono mt-0.5 lowercase">
                                            <%= adm.email %>
                                        </p>
                                    </div>
                                </div>

                                <div class="flex items-center gap-3">
                                    <form action="/admin/update-role" method="POST">
                                        <input type="hidden" name="adminId" value="<%= adm._id %>">
                                        <select name="newRole" onchange="this.form.submit()"
                                            class="bg-zinc-900 border border-zinc-700 text-zinc-300 text-[10px] font-bold uppercase py-2 px-3 rounded-lg focus:border-red-500 outline-none cursor-pointer hover:bg-zinc-800">
                                            <option value="admin" <%=adm.role==='admin' ? 'selected' : '' %>>Admin
                                            </option>
                                            <option value="warden" <%=adm.role==='warden' ? 'selected' : '' %>>Warden
                                            </option>
                                        </select>
                                    </form>

                                    <% if (user._id.toString() !==adm._id.toString()) { %>
                                        <form action="/admin/remove-role/<%= adm._id %>" method="POST"
                                            onsubmit="return confirm('Revoke all administrative access for this user?')">
                                            <button
                                                class="w-8 h-8 rounded-lg border border-zinc-800 text-zinc-700 hover:text-red-500 hover:border-red-900 transition-all">
                                                <i class="ri-close-circle-line"></i>
                                            </button>
                                        </form>
                                        <% } %>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>
            </div>
            <div id="residentModal" class="fixed inset-0 z-[150] hidden flex items-center justify-center p-4 pt-6">
                <div class="absolute inset-0 bg-black/90 backdrop-blur-md" onclick="toggleResidentModal()"></div>
                <div
                    class="relative bg-zinc-900 border border-zinc-800 w-full max-w-5xl rounded-[2.5rem] shadow-2xl overflow-hidden">
                    <div
                        class="p-8 border-b border-zinc-800 bg-zinc-950/50 flex flex-col md:flex-row justify-between items-center gap-6">
                        <div>
                            <h3 class="text-white font-serif italic text-2xl">Resident Directory</h3>
                            <p class="text-[10px] text-zinc-500 uppercase tracking-widest mt-1">Authorized Scholars</p>
                        </div>
                        <div class="relative w-full md:w-80 group">
                            <i
                                class="ri-search-2-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-red-600 transition-colors"></i>
                            <input type="text" id="residentSearch" onkeyup="filterResidents()"
                                placeholder="Search by name, room, or ID..."
                                class="w-full bg-zinc-900 border border-zinc-700 rounded-full py-3 pl-12 pr-6 text-xs text-white outline-none focus:border-red-700 transition-all">
                        </div>
                    </div>

                    <div class="max-h-[60vh] overflow-y-auto">
                        <table class="w-full text-left border-collapse" id="residentTable">
                            <thead
                                class="sticky top-0 bg-zinc-950 text-zinc-500 text-[9px] uppercase tracking-widest font-black border-b border-zinc-500">
                                <tr>
                                    <th class="p-6">Resident</th>
                                    <th class="p-6 text-center">Enrollment No.</th>
                                    <th class="p-6 whitespace-nowrap">Room No.</th>
                                    <th class="p-6 text-right text-red-600">Remove</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-700">
                                <% allStudents.forEach(st=> { %>
                                    <tr class="resident-row hover:bg-zinc-700/30 transition-colors group">
                                        <td class="p-6">
                                            <p
                                                class="text-zinc-200 font-bold text-sm group-hover:text-white transition-colors">
                                                <%= st.name %>
                                            </p>
                                            <p class="text-[10px] text-zinc-500 font-mono lowercase">
                                                <%= st.email %>
                                            </p>
                                        </td>
                                        <td
                                            class="p-6 font-mono text-xs text-zinc-400 uppercase tracking-tighter text-center">
                                            <%= st.enrollmentNumber %>
                                        </td>
                                        <td class="p-6">
                                            <span
                                                class="px-3 py-1 rounded bg-zinc-800 border border-zinc-700 text-zinc-300 font-bold text-[10px]">
                                                <%= st.roomNumber %>
                                            </span>
                                        </td>
                                        <td class="p-6 text-right">
                                            <form action="/admin/remove-resident/<%= st._id %>" method="POST"
                                                onsubmit="return confirm('Remove this resident from the registry?')">
                                                <button
                                                    class="w-10 h-10 rounded-xl bg-red-900/10 border border-red-900/20 text-red-600 hover:bg-red-600 hover:text-white transition-all">
                                                    <i class="ri-user-unfollow-line"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div id="announcementModal" class="fixed inset-0 z-[170] hidden flex items-center justify-center p-4 pt-6">
                <div class="absolute inset-0 bg-black/90 backdrop-blur-md" onclick="toggleAnnouncementModal()"></div>
                <div
                    class="relative bg-zinc-900 border border-zinc-800 w-full max-w-lg rounded-[2.5rem] shadow-2xl overflow-hidden">
                    <div class="p-6 border-b border-zinc-800 flex justify-between items-center bg-zinc-950/50">
                        <div>
                            <h3 class="text-white font-serif italic text-xl">New Broadcast</h3>
                            <p class="text-[9px] text-zinc-500 uppercase tracking-widest mt-1">Publish to Notice Board
                            </p>
                        </div>
                        <button onclick="toggleAnnouncementModal()" class="text-zinc-600 hover:text-white"><i
                                class="ri-close-line text-2xl"></i></button>
                    </div>

                    <form action="/admin/announcements/new" method="POST" class="p-4 space-y-8">
                        <div>
                            <label
                                class="block text-[9px] font-black uppercase text-zinc-500 mb-2 tracking-[0.2em]">Category</label>
                            <div class="grid grid-cols-2 gap-4">
                                <label
                                    class="relative flex items-center justify-center p-4 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer hover:border-red-900 transition-all has-[:checked]:border-red-600 has-[:checked]:bg-red-950/10 group">
                                    <input type="radio" name="category" value="Hostel" checked class="hidden">
                                    <span
                                        class="text-[10px] font-black text-zinc-500 group-hover:text-zinc-300 uppercase tracking-widest">Hostel</span>
                                </label>
                                <label
                                    class="relative flex items-center justify-center p-4 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer hover:border-blue-900 transition-all has-[:checked]:border-blue-600 has-[:checked]:bg-blue-950/10 group">
                                    <input type="radio" name="category" value="College" class="hidden">
                                    <span
                                        class="text-[10px] font-black text-zinc-500 group-hover:text-zinc-300 uppercase tracking-widest">College</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label
                                class="block text-[9px] font-black uppercase text-zinc-500 mb-2 tracking-[0.2em]">Announcement
                                Body</label>
                            <textarea name="content" required rows="3" maxlength="250" style="resize: none;"
                                class="w-full bg-zinc-950 border border-zinc-800 rounded-2xl py-5 px-6 text-white placeholder:text-zinc-500 focus:border-blue-600 outline-none transition-all font-serif"
                                placeholder="Write about announcement here... (Limit 250 characters)"></textarea>
                        </div>

                        <div>
                            <label
                                class="block text-[9px] font-black uppercase text-zinc-500 mb-2 tracking-[0.2em]">Available
                                Link (Optional)</label>
                            <div class="relative">
                                <i class="ri-link absolute left-5 top-1/2 -translate-y-1/2 text-zinc-700"></i>
                                <input type="url" name="link"
                                    class="w-full bg-zinc-950 border border-zinc-800 rounded-xl py-4 pl-14 pr-6 text-xs text-white focus:border-blue-600 outline-none transition-all placeholder:text-zinc-500"
                                    placeholder="https://official-source.com">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-blue-700 text-white font-black py-5 rounded-2xl hover:bg-white hover:text-black transition-all duration-700 text-[10px] uppercase tracking-[0.4em] shadow-xl shadow-blue-900/20">
                            Post
                        </button>
                    </form>
                </div>
            </div>

            <main class="min-h-screen bg-stone-950 p-6 md:p-12 text-stone-50 font-sans">
                <div class="max-w-7xl mx-auto">
                    <div
                        class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-12 gap-8 bg-zinc-900/20 p-6 md:p-8 rounded-[2rem] md:rounded-[2.5rem] border border-zinc-800/50 backdrop-blur-md">

                        <div
                            class="flex flex-col sm:flex-row items-center sm:items-start gap-6 w-full lg:w-auto text-center sm:text-left">
                            <div class="relative shrink-0">
                                <div
                                    class="w-20 h-20 rounded-[1.5rem] bg-zinc-950 border border-red-900/50 flex items-center justify-center shadow-2xl">
                                    <i class="ri-shield-user-line text-4xl text-red-600"></i>
                                </div>
                                <div
                                    class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full bg-stone-950 border border-zinc-800 flex items-center justify-center">
                                    <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                                </div>
                            </div>

                            <div class="flex-grow">
                                <p class="text-zinc-500 text-[8px] font-black uppercase tracking-[0.4em] mb-2">
                                    Authenticated Admin
                                </p>
                                <h2
                                    class="text-3xl md:text-4xl font-serif italic text-white tracking-tighter leading-tight mb-3">
                                    <%= user.name %>
                                </h2>

                                <div class="flex flex-wrap justify-center sm:justify-start gap-2">
                                    <span
                                        class="text-[8px] px-3 py-1.5 rounded-lg bg-red-950/30 text-red-500 border border-red-900/50 uppercase font-black tracking-widest whitespace-nowrap">
                                        Status: <%= user.role %>
                                    </span>
                                    <span
                                        class="text-[8px] px-3 py-1.5 rounded-lg bg-zinc-950 text-zinc-400 border border-zinc-600 uppercase font-bold tracking-widest whitespace-nowrap">
                                        ID: HH-<%= user._id.toString().slice(-5).toUpperCase() %>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row gap-3 w-full lg:w-auto text-center">
                            <a href="/admin/register-student"
                                class="bg-red-700 text-white px-6 py-4 rounded-xl shadow-lg shadow-red-900/20 hover:bg-white hover:text-black transition-all flex items-center justify-center gap-3 font-bold text-[10px] uppercase tracking-widest">
                                <i class="ri-user-add-line text-lg"></i> Register Resident
                            </a>
                        </div>
                    </div>

                    <a href="javascript:void(0)" onclick="history.back()"
                        class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2 mb-12">
                        <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                        <span>Back</span>
                    </a>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
                        <div
                            class="bg-zinc-900/40 border border-zinc-800 p-8 rounded-[2rem] shadow-xl group hover:border-red-700 transition-all duration-500">
                            <div class="flex justify-between items-start mb-4">
                                <p
                                    class="text-zinc-500 group-hover:text-red-600 text-[10px] font-black uppercase tracking-[0.2em]">
                                    Total
                                    Residents
                                </p>
                                <i
                                    class="ri-group-line text-zinc-800 text-3xl group-hover:text-red-600 transition-colors"></i>
                            </div>
                            <h3 class="text-5xl font-serif italic text-white">
                                <%= studentCount %>
                            </h3>
                            <button onclick="toggleResidentModal()"
                                class="mt-6 w-full py-3 rounded-xl bg-zinc-950 border border-zinc-800 text-[9px] font-black uppercase tracking-widest text-zinc-400 hover:text-white hover:bg-zinc-900 transition-all">
                                View Directory
                            </button>
                        </div>

                        <div
                            class="bg-zinc-900/40 border border-zinc-800 p-8 rounded-[2rem] shadow-xl group hover:border-orange-500 transition-all duration-500">
                            <div class="flex justify-between items-start mb-4">
                                <p
                                    class="text-zinc-500 group-hover:text-orange-500 text-[10px] font-black uppercase tracking-[0.2em]">
                                    Pending
                                    Issues</p>
                                <i
                                    class="ri-error-warning-line text-zinc-800 text-3xl group-hover:text-orange-500 transition-colors"></i>
                            </div>
                            <h3 class="text-5xl font-serif italic text-orange-500">
                                <%= pendingCount %>
                            </h3>
                            <a href="/admin/complaints"
                                class="mt-6 block w-full py-3 text-center rounded-xl bg-zinc-950 border border-zinc-800 text-[9px] font-black uppercase tracking-widest text-zinc-400 hover:text-white hover:bg-zinc-900 transition-all">
                                Review Logs
                            </a>
                        </div>

                        <div
                            class="bg-zinc-900/40 border border-zinc-800 p-8 rounded-[2rem] shadow-xl group hover:border-blue-500 transition-all duration-500">
                            <div class="flex justify-between items-start mb-4">
                                <p
                                    class="text-zinc-500 group-hover:text-blue-500 text-[10px] font-black uppercase tracking-[0.2em]">
                                    Authority
                                    Staff</p>
                                <i
                                    class="ri-shield-user-line text-zinc-800 text-3xl group-hover:text-blue-500 transition-colors"></i>
                            </div>
                            <h3 class="text-5xl font-serif italic text-white">
                                <%= adminsCount %>
                            </h3>
                            <button onclick="toggleAdminModal()"
                                class="mt-6 w-full py-3 rounded-xl bg-zinc-950 border border-zinc-800 text-[9px] font-black uppercase tracking-widest text-zinc-400 hover:text-white hover:bg-zinc-900 transition-all">
                                Manage Access
                            </button>
                        </div>

                        <div class="grid grid-rows-2 gap-4">
                            <button onclick="toggleAnnouncementModal()"
                                class="bg-blue-900/10 border border-blue-900/30 p-4 rounded-2xl hover:bg-blue-900/20 hover:border-blue-600 transition-all flex items-center justify-between group">
                                <span class="text-[9px] font-black uppercase tracking-widest text-blue-400">New
                                    Announcement</span>
                                <i
                                    class="ri-megaphone-line text-blue-500 group-hover:rotate-12 transition-transform"></i>
                            </button>
                            <a href="/student/dashboard"
                                class="bg-emerald-900/10 border border-emerald-900/30 p-4 rounded-2xl hover:bg-emerald-900/20 hover:border-emerald-600 transition-all flex items-center justify-between group">
                                <span class="text-[9px] font-black uppercase tracking-widest text-emerald-400">View
                                    Profile</span>
                                <i class="ri-user-line text-emerald-500 group-hover:scale-110 transition-transform"></i>
                            </a>
                        </div>
                    </div>



                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                        <a href="/admin/resources/new"
                            class="group bg-zinc-900/30 border border-zinc-800 p-6 rounded-2xl hover:border-emerald-600 transition-all duration-500 flex items-center justify-between shadow-lg">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-12 h-12 rounded-xl bg-emerald-900/10 border border-emerald-900/30 flex items-center justify-center text-emerald-600 group-hover:bg-emerald-600 group-hover:text-white transition-all">
                                    <i class="ri-book-open-line text-xl"></i>
                                </div>
                                <div>
                                    <p class="text-[9px] font-black text-zinc-500 uppercase tracking-[0.2em]">Academic
                                        Vault</p>
                                    <h4 class="text-sm font-bold text-zinc-200">Upload Material</h4>
                                </div>
                            </div>
                            <i
                                class="ri-arrow-right-s-line text-zinc-700 group-hover:text-emerald-500 transition-colors"></i>
                        </a>

                        <a href="/scholars"
                            class="group bg-zinc-900/30 border border-zinc-800 p-6 rounded-2xl hover:border-yellow-600 transition-all duration-500 flex items-center justify-between shadow-lg">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-12 h-12 rounded-xl bg-yellow-900/10 border border-yellow-900/30 flex items-center justify-center text-yellow-600 group-hover:bg-yellow-600 group-hover:text-white transition-all">
                                    <i class="ri-honour-line text-xl"></i>
                                </div>
                                <div>
                                    <p class="text-[9px] font-black text-zinc-500 uppercase tracking-[0.2em]">Historical
                                        Registry</p>
                                    <h4 class="text-sm font-bold text-zinc-200">Update Scholars</h4>
                                </div>
                            </div>
                            <i
                                class="ri-arrow-right-s-line text-zinc-700 group-hover:text-yellow-500 transition-colors"></i>
                        </a>
                        <a href="/admin/essentials/new"
                            class="group bg-zinc-900/30 border border-zinc-800 p-6 rounded-2xl hover:border-pink-600 transition-all duration-500 flex items-center justify-between shadow-lg">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-12 h-12 rounded-xl bg-pink-900/10 border border-pink-900/30 flex items-center justify-center text-pink-600 group-hover:bg-pink-600 group-hover:text-white transition-all">
                                    <i class="ri-heart-add-line text-xl"></i>
                                </div>
                                <div>
                                    <p class="text-[9px] font-black text-zinc-500 uppercase tracking-[0.2em]">Local
                                        Directory</p>
                                    <h4 class="text-sm font-bold text-zinc-200">Add New</h4>
                                </div>
                            </div>
                            <i
                                class="ri-arrow-right-s-line text-zinc-700 group-hover:text-yellow-500 transition-colors"></i>
                        </a>
                        <a href="/admin/reviews"
                            class="group bg-zinc-900/30 border border-zinc-800 p-6 rounded-2xl hover:border-purple-600 transition-all duration-500 flex items-center justify-between shadow-lg">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-12 h-12 rounded-xl bg-purple-900/10 border border-purple-900/30 flex items-center justify-center text-pink-600 group-hover:bg-purple-600 group-hover:text-white transition-all">
                                    <i class="ri-feedback-line text-xl"></i>
                                </div>
                                <div>
                                    <p class="text-[9px] font-black text-zinc-500 uppercase tracking-[0.2em]">User
                                        Reviews</p>
                                    <h4 class="text-sm font-bold text-zinc-200">View All</h4>
                                </div>
                            </div>
                            <i
                                class="ri-arrow-right-s-line text-zinc-700 group-hover:text-yellow-500 transition-colors"></i>
                        </a>
                    </div>
                    <div
                        class="bg-zinc-900/30 border border-zinc-800 rounded-[2.5rem] shadow-2xl overflow-hidden backdrop-blur-sm">
                        <div
                            class="p-8 border-b border-zinc-800 flex flex-col sm:flex-row justify-between items-center gap-4">
                            <div>
                                <h4 class="text-2xl font-serif italic text-white">Filed Complaints</h4>
                                <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-widest mt-1">Latest
                                    Resident
                                    Submissions</p>
                            </div>
                            <a href="/admin/complaints"
                                class="text-red-500 text-[9px] font-black uppercase tracking-[0.2em] border border-red-500/20 px-4 py-2 rounded-full hover:bg-red-500 hover:text-white transition-all">
                                View all <i class="ri-arrow-right-up-line"></i>
                            </a>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr
                                        class="bg-zinc-950/50 text-zinc-500 text-[9px] uppercase font-black tracking-[0.3em]">
                                        <th class="p-6">Resident</th>
                                        <th class="p-6 whitespace-nowrap">Room No.</th>
                                        <th class="p-6">Domain</th>
                                        <th class="p-6 text-right">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="text-sm font-sans divide-y divide-zinc-800/50">
                                    <% if(complaints.length> 0) { %>
                                        <% complaints.forEach(c=> { %>
                                            <tr class="hover:bg-zinc-800/30 transition-colors cursor-pointer group"
                                                onclick="window.location='/admin/complaints/<%= c._id %>'">
                                                <td class="p-6">
                                                    <p
                                                        class="font-bold text-zinc-200 whitespace-nowrap group-hover:text-red-500 transition-colors">
                                                        <%= c.student ? c.student.name : 'System Record' %>
                                                    </p>

                                                </td>
                                                <td class="p-6 font-mono text-xs text-zinc-400">
                                                    <%= c.roomNumber %>
                                                </td>
                                                <td class="p-6">
                                                    <span
                                                        class="text-[10px] text-zinc-400 bg-zinc-800/50 px-3 py-1 rounded-lg border border-zinc-800">
                                                        <%= c.category %>
                                                    </span>
                                                </td>
                                                <td class="p-6 text-right">
                                                    <span
                                                        class="px-4 py-1.5 rounded-full text-[9px] font-black uppercase whitespace-nowrap tracking-tighter
                                            <%= c.status === 'Pending' ? 'bg-red-500/10 text-red-500 border border-red-500/20' : 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' %>">
                                                        <%= c.status %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="4" class="p-20 text-center">
                                                            <i
                                                                class="ri-ghost-line text-5xl text-zinc-800 mb-4 block"></i>
                                                            <p class="text-zinc-600 font-serif italic">The digital
                                                                register is currently empty</p>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>


                </div>
            </main>

            <script>
                function toggleAdminModal() {
                    const modal = document.getElementById('adminModal');
                    modal.classList.toggle('hidden');
                    document.body.classList.toggle('overflow-hidden');
                }

                function toggleResidentModal() {
                    const modal = document.getElementById('residentModal');
                    modal.classList.toggle('hidden');
                    document.body.classList.toggle('overflow-hidden');
                }

                function filterResidents() {
                    const input = document.getElementById('residentSearch').value.toUpperCase();
                    const rows = document.querySelectorAll('.resident-row');

                    rows.forEach(row => {
                        const text = row.innerText.toUpperCase();
                        row.style.display = text.includes(input) ? "" : "none";
                    });
                }

                function toggleAnnouncementModal() {
                    const modal = document.getElementById('announcementModal');
                    modal.classList.toggle('hidden');
                    document.body.classList.toggle('overflow-hidden');
                }
                if (window.location.hash === '#announcementModal') {
                    toggleAnnouncementModal();
                }
            </script>
            <%- include('../partials/footer') %>