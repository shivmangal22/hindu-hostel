<%- include('../partials/head') %>
    <%- include('../partials/nav') %>
        <%- include('../partials/flash') %>

            <main class="min-h-screen bg-zinc-950 text-stone-50 py-20 font-serif">
                <div class="max-w-2xl mx-auto px-6">
                    <header class="mb-12 border-b border-zinc-800 pb-8">
                        <h1 class="text-4xl italic tracking-tighter">Add New Scholar</h1>
                        <p class="text-red-500 font-bold font-sans uppercase tracking-[0.2em] text-[10px] mt-2">Hall of
                            Eminence
                            Registry</p>
                    </header>
                    <a href="javascript:void(0)" onclick="history.back()"
                        class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2 mb-6">
                        <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                        <span>Back</span>
                    </a>
                    <form action="/admin/scholars/new" method="POST" class="space-y-8 font-sans">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-widest text-red-700 mb-3">Full
                                Name</label>
                            <input type="text" name="name" required placeholder="e.g. Pt. Madan Mohan Malaviya"
                                class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-red-700 outline-none transition-all">
                        </div>

                        <div>
                            <label class="block text-xs font-bold uppercase tracking-widest text-red-700 mb-3">Role /
                                Achievement</label>
                            <input type="text" name="role" required placeholder="e.g. Founder of BHU | Bharat Ratna"
                                class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-red-700 outline-none transition-all">
                        </div>

                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <label
                                    class="block text-xs font-bold uppercase tracking-widest text-red-700 mb-3">Category
                                    Tag</label>
                                <input type="text" name="tag" required placeholder="e.g. National Icon"
                                    class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-red-700 outline-none transition-all">
                            </div>
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-widest text-red-700 mb-3">Era /
                                    Years</label>
                                <input type="text" name="era" required placeholder="e.g. 1920s"
                                    class="w-full bg-zinc-900 border border-zinc-800 rounded-xl p-4 focus:border-red-700 outline-none transition-all">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-red-700 hover:bg-red-600 text-white font-bold py-5 rounded-xl transition-all shadow-xl">
                            ADD TO ARCHIVES
                        </button>
                    </form>
                </div>
            </main>

            <%- include('../partials/footer') %>