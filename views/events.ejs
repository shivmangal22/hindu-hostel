<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <%- include('partials/flash') %>

            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

            <main class="min-h-screen bg-zinc-950 text-stone-50 pb-20 font-serif overflow-x-hidden">
                <section class="relative py-12 px-6 bg-zinc-900/50 border-b border-zinc-600 overflow-hidden">
                    <div class="absolute inset-0 opacity-20 pointer-events-none">
                        <div class="absolute -top-24 -right-24 w-96 h-96 bg-red-900 rounded-full blur-[120px]"></div>
                    </div>

                    <div class="max-w-5xl mx-auto text-center relative z-10">
                        <h2 class="text-4xl md:text-6xl mb-4 tracking-tighter italic">Chronicles</h2>
                        <p class="text-red-600 tracking-[0.4em] uppercase text-[10px] md:text-xs font-sans font-bold">
                            Archiving the Legacy of Hindu Hostel
                        </p>
                    </div>
                </section>

                <div class="max-w-5xl mx-auto px-6 mt-12">
                    <% if (locals.user && (user.role==='warden' || user.role==='admin' ) ) { %>
                        <div
                            class="mb-16 p-8 bg-zinc-900/80 border border-zinc-800 rounded-3xl flex justify-between items-center gap-6 flex-wrap group shadow-2xl backdrop-blur-md">
                            <div>
                                <h4 class="text-white font-sans font-bold text-lg">Curate the Events</h4>
                                <p class="text-zinc-500 text-sm font-sans italic">Update the events registry with new
                                    residential memories.</p>
                            </div>
                            <a href="/admin/events/new"
                                class="bg-red-700 hover:bg-white hover:text-black text-white px-8 py-3 rounded-full font-sans font-bold text-[10px] tracking-widest transition-all uppercase shadow-lg shadow-red-900/20">
                                <i class="ri-add-line mr-2"></i>Add New Event
                            </a>
                        </div>
                        <% } %>
                            <a href="javascript:void(0)" onclick="history.back()"
                                class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2">
                                <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                                <span>Back</span>
                            </a>

                            <div class="relative space-y-40">
                                <div
                                    class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[1px] bg-gradient-to-b from-red-800/50 via-zinc-800 to-transparent hidden lg:block">
                                </div>

                                <% if (typeof events !=='undefined' && events.length> 0) { %>
                                    <% events.forEach((event, index)=> { %>
                                        <article
                                            class="relative group animate-in fade-in slide-in-from-bottom-10 duration-1000">
                                            <div
                                                class="absolute left-1/2 -translate-x-1/2 -top-12 w-4 h-4 rounded-full border-2 border-red-700 bg-zinc-950 z-20 hidden lg:block group-hover:bg-red-700 transition-colors shadow-[0_0_15px_rgba(185,28,28,0.5)]">
                                            </div>

                                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                                                <div class="<%= index % 2 === 0 ? 'lg:order-1' : 'lg:order-2' %>">
                                                    <div
                                                        class="bg-zinc-900 rounded-2xl overflow-hidden border border-zinc-800 shadow-[0_20px_50px_rgba(0,0,0,0.5)] relative">
                                                        <div
                                                            class="swiper mySwiper-<%= event._id %> h-[300px] md:h-[400px]">
                                                            <div class="swiper-wrapper">
                                                                <% event.images.forEach(img=> { %>
                                                                    <div class="swiper-slide">
                                                                        <img src="<%= img %>"
                                                                            class="w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-1000 scale-105 group-hover:scale-100">
                                                                    </div>
                                                                    <% }) %>
                                                            </div>
                                                            <div class="swiper-pagination !bottom-4"></div>
                                                            <div
                                                                class="swiper-button-next !text-white !scale-50 opacity-0 group-hover:opacity-100 transition-opacity">
                                                            </div>
                                                            <div
                                                                class="swiper-button-prev !text-white !scale-50 opacity-0 group-hover:opacity-100 transition-opacity">
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div
                                                    class="<%= index % 2 === 0 ? 'lg:order-2 lg:pl-12' : 'lg:order-1 lg:pr-12' %>">
                                                    <h3
                                                        class="text-3xl md:text-4xl font-bold mb-6 text-white tracking-tight italic group-hover:text-red-500 transition-colors">
                                                        <%= event.title %>
                                                    </h3>

                                                    <p
                                                        class="text-zinc-400 font-sans text-base leading-relaxed italic mb-8 opacity-90">
                                                        <%= event.description %>
                                                    </p>

                                                    <div class="space-y-6">
                                                        <% if(event.chiefGuests && event.chiefGuests.length> 0) { %>
                                                            <div
                                                                class="bg-zinc-900/80 p-4 border-l-2 border-yellow-600 rounded-r-xl">
                                                                <p
                                                                    class="text-[9px] uppercase text-yellow-600 mb-2 font-sans font-bold tracking-[0.2em]">
                                                                    Eminent Guests</p>
                                                                <ul
                                                                    class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-zinc-300 font-sans italic">
                                                                    <% event.chiefGuests.forEach(cg=> { %>
                                                                        <li class="flex items-center gap-2"><i
                                                                                class="ri-user-star-line text-yellow-600"></i>
                                                                            <%= cg %>
                                                                        </li>
                                                                        <% }) %>
                                                                </ul>
                                                            </div>
                                                            <% } %>

                                                                <% if(event.winners && event.winners.length> 0) { %>
                                                                    <div
                                                                        class="bg-zinc-900/80 p-4 border-l-2 border-emerald-800 rounded-r-xl">
                                                                        <p
                                                                            class="text-[9px] uppercase text-emerald-600 mb-2 font-sans font-bold tracking-[0.2em]">
                                                                            Winners</p>
                                                                        <ul
                                                                            class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-zinc-300 font-sans italic">
                                                                            <% event.winners.forEach(w=> { %>
                                                                                <li class="flex items-center gap-2"><i
                                                                                        class="ri-medal-line text-emerald-600"></i>
                                                                                    <%= w %>
                                                                                </li>
                                                                                <% }) %>
                                                                        </ul>
                                                                    </div>
                                                                    <% } %>
                                                    </div>

                                                    <% if (locals.user && (user.role==='warden' || user.role==='admin'
                                                        )) { %>
                                                        <div class="flex gap-6 mt-10 pt-6 border-t border-zinc-900">
                                                            <a href="/admin/events/edit/<%= event._id %>"
                                                                class="text-[10px] font-sans font-bold text-blue-500 hover:text-white flex items-center gap-1 uppercase tracking-widest transition-colors">
                                                                <i class="ri-edit-box-line"></i> Edit Entry
                                                            </a>
                                                            <form action="/admin/events/delete/<%= event._id %>"
                                                                method="POST"
                                                                onsubmit="return confirm('Excise this memory from the archives?')">
                                                                <button
                                                                    class="text-[10px] font-sans font-bold text-red-500 hover:text-red-700 flex items-center gap-1 uppercase tracking-widest transition-colors">
                                                                    <i class="ri-delete-bin-line"></i> Remove
                                                                </button>
                                                            </form>
                                                        </div>
                                                        <% } %>
                                                </div>
                                            </div>
                                        </article>
                                        <% }) %>
                                            <% } else { %>
                                                <div
                                                    class="py-32 text-center border border-dashed border-zinc-500 rounded-3xl bg-zinc-900/20">
                                                    <i class="ri-history-line text-6xl text-zinc-400 mb-4 block"></i>
                                                    <p
                                                        class="text-zinc-400 italic font-sans uppercase text-[9px] font-bold tracking-widest">
                                                        The archives are waiting for their first entry</p>
                                                </div>
                                                <% } %>
                            </div>
                </div>
            </main>

            <%- include('partials/footer') %>

                <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

                <script>
                    document.addEventListener('DOMContentLoaded', function () {
        <% if (typeof events !== 'undefined' && events.length > 0) { %>
            <% events.forEach(event => { %>
                        new Swiper(".mySwiper-<%= event._id %>", {
                            loop: true,
                            speed: 1000,
                            parallax: true,
                            autoplay: {
                                delay: 5000,
                                disableOnInteraction: false,
                            },
                            effect: "creative",
                            creativeEffect: {
                                prev: { shadow: true, translate: [0, 0, -400] },
                                next: { translate: ["100%", 0, 0] },
                            },
                            pagination: {
                                el: ".mySwiper-<%= event._id %> .swiper-pagination",
                                clickable: true,
                            },
                            navigation: {
                                nextEl: ".mySwiper-<%= event._id %> .swiper-button-next",
                                prevEl: ".mySwiper-<%= event._id %> .swiper-button-prev",
                            },
                        });
            <% }) %>
        <% } %>
    });
                </script>