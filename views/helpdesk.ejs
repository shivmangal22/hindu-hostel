<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <%- include('partials/flash') %>

            <main class="min-h-screen bg-zinc-950 text-stone-50 pb-20 font-serif overflow-x-hidden">
                <header class="py-12 bg-zinc-900 border-b border-zinc-600 relative overflow-hidden">
                    <div class="absolute inset-0 opacity-10 pointer-events-none">
                        <div class="absolute -top-24 -right-24 w-96 h-96 bg-emerald-900 rounded-full blur-[120px]">
                        </div>
                    </div>

                    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
                        <div
                            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-950 border border-zinc-800 mb-6">
                            <div class="w-1.5 h-1.5 rounded-full bg-red-600 animate-pulse"></div>
                            <span id="liveClock"
                                class="text-[10px] font-mono font-bold text-zinc-400 tracking-widest uppercase text-center">Loading
                                Hub Time...</span>
                        </div>
                        <h1 class="text-4xl md:text-5xl italic tracking-tighter mb-4 text-white"><i
                                class="ri-heart-add-line"></i> Helpdesk</h1>
                        <p class="text-emerald-500 font-sans font-black tracking-[0.4em] text-[10px] uppercase">
                            Critical Essentials & Emergency Contacts
                        </p>
                    </div>
                </header>

                <div class="max-w-6xl mx-auto px-6 mt-12">
                    <a href="javascript:void(0)" onclick="history.back()"
                        class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2 mb-12">
                        <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                        <span>Back</span>
                    </a>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <% if (essentials && essentials.length> 0) { %>
                            <% essentials.forEach(service=> { %>
                                <div
                                    class="relative bg-zinc-900/40 border border-zinc-800 p-8 rounded-[2rem] hover:bg-zinc-900 hover:border-zinc-700 transition-all duration-500 group shadow-2xl flex flex-col h-full">

                                    <div class="flex justify-between items-start mb-8">
                                        <span
                                            class="px-3 py-1 rounded-lg text-[9px] font-black font-sans uppercase tracking-[0.15em] bg-zinc-950 border border-zinc-800 text-zinc-500 group-hover:text-zinc-300 transition-colors">
                                            <%= service.category %>
                                        </span>

                                        <% if (service.isOpen247) { %>
                                            <div
                                                class="flex items-center gap-2 px-3 py-1 rounded-lg bg-emerald-950/30 border border-emerald-900/50">
                                                <span class="relative flex h-2 w-2">
                                                    <span
                                                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                                    <span
                                                        class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                                                </span>
                                                <span
                                                    class="text-[9px] font-black font-sans uppercase tracking-widest text-emerald-500">24/7
                                                    Active</span>
                                            </div>
                                            <% } %>
                                    </div>

                                    <div class="flex-grow">
                                        <h3
                                            class="text-2xl font-bold mb-3 text-white tracking-tight group-hover:text-emerald-500 transition-colors italic">
                                            <%= service.name %>
                                        </h3>
                                        <div
                                            class="flex items-start gap-3 text-zinc-400 group-hover:text-zinc-200 transition-colors">
                                            <i class="ri-map-pin-2-line text-emerald-600 mt-1"></i>
                                            <p class="text-sm font-sans leading-relaxed italic">
                                                <%= service.address %> <br>
                                                    <span
                                                        class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mt-1 block">Est.
                                                        Distance: <%= service.distance %></span>
                                            </p>
                                        </div>
                                    </div>

                                    <div class="mt-10 pt-8 border-t border-zinc-800 flex items-center justify-between">
                                        <div class="flex gap-4">
                                            <% if (service.phone) { %>
                                                <a href="tel:<%= service.phone %>" title="Emergency Call"
                                                    class="w-12 h-12 rounded-2xl bg-emerald-900/20 border border-emerald-900 flex items-center justify-center text-emerald-500 hover:bg-emerald-500 hover:text-white transition-all shadow-lg">
                                                    <i class="ri-phone-fill text-xl"></i>
                                                </a>
                                                <% } %>

                                                    <% if (service.website) { %>
                                                        <a href="<%= service.website %>" target="_blank"
                                                            title="Visit Portal"
                                                            class="w-12 h-12 rounded-2xl bg-blue-900/20 border border-blue-900 flex items-center justify-center text-blue-400 hover:bg-blue-400 hover:text-white transition-all shadow-lg">
                                                            <i class="ri-global-line text-xl"></i>
                                                        </a>
                                                        <% } %>
                                                            <% if (service.email) { %>
                                                                <a href="<%= service.email %>" target="_blank"
                                                                    title="Visit Portal"
                                                                    class="w-12 h-12 rounded-2xl bg-red-900/20 border border-red-900 flex items-center justify-center text-red-400 hover:bg-red-400 hover:text-white transition-all shadow-lg">
                                                                    <i class="ri-mail-line text-xl"></i>
                                                                </a>
                                                                <% } %>
                                        </div>

                                        <% if (locals.user && (user.role==='warden' || user.role==='admin' )) { %>
                                            <form action="/admin/essentials/delete/<%= service._id %>" method="POST"
                                                onsubmit="return confirm('Remove this infrastructure record?')">
                                                <button class="p-2 text-zinc-700 hover:text-red-500 transition-colors">
                                                    <i class="ri-delete-bin-7-line text-lg"></i>
                                                </button>
                                            </form>
                                            <% } %>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div
                                            class="col-span-full py-32 text-center border-2 border-dashed border-zinc-700 rounded-[3rem]">
                                            <i class="ri-road-map-line text-6xl text-zinc-400 mb-6 block"></i>
                                            <p
                                                class="text-zinc-400 italic font-sans uppercase text-[10px] tracking-[0.4em]">
                                                Infrastructure Mapping in Progress...</p>
                                        </div>
                                        <% } %>
                    </div>
                </div>

                <% if (locals.user && (user.role==='warden' || user.role==='admin' )) { %>
                    <a href="/admin/essentials/new"
                        class="fixed bottom-10 right-10 bg-emerald-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(16,185,129,0.3)] hover:scale-110 hover:rotate-90 transition-all z-50">
                        <i class="ri-add-line text-3xl"></i>
                    </a>
                    <% } %>
            </main>

            <script>
                function updateClock() {
                    const now = new Date();
                    const options = { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true };
                    document.getElementById('liveClock').innerText = 'Time: ' + now.toLocaleTimeString('en-GB', options);
                }
                setInterval(updateClock, 1000);
                updateClock();
            </script>

            <%- include('partials/footer') %>