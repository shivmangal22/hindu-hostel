<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <%- include('partials/flash') %>

            <main class="min-h-screen bg-zinc-950 text-stone-50 pb-20 font-serif overflow-x-hidden">
                <section class="relative bg-zinc-900 py-12 px-6 border-b border-zinc-600 shadow-2xl overflow-hidden">
                    <div class="absolute inset-0 opacity-15 pointer-events-none">
                        <div class="absolute -top-48 -left-48 w-[600px] h-[600px] bg-red-900 rounded-full blur-[150px]">
                        </div>
                        <div
                            class="absolute -bottom-48 -right-48 w-[400px] h-[400px] bg-zinc-800 rounded-full blur-[120px]">
                        </div>
                    </div>

                    <div class="max-w-4xl mx-auto text-center relative z-10">
                        <h1 class="text-4xl md:text-6xl mb-6 tracking-tighter italic">A Legacy Since 1901</h1>
                        <p class="text-red-600 tracking-[0.5em] uppercase text-[10px] md:text-xs font-sans font-black">
                            The Heritage of Prayagraj
                        </p>
                    </div>
                </section>

                <div class="max-w-4xl mx-auto px-6 mt-20">
                    <a href="javascript:void(0)" onclick="history.back()"
                        class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2 mb-6">
                        <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                        <span>Back</span>
                    </a>

                    <article class="leading-relaxed text-lg italic opacity-90 mb-24 relative">
                        <div class="absolute -left-10 top-0 text-7xl text-red-900/20 font-serif">“</div>
                        <p class="mb-8 text-zinc-300 text-center leading-loose max-w-2xl mx-auto">
                            Established in the early 20th century, Hindu Hostel stands as a testament to the rich
                            educational heritage of the University of Allahabad.
                        </p>

                        <div
                            class="border-y border-red-900/30 py-12 my-16 bg-zinc-900/20 backdrop-blur-sm px-8 relative">
                            <h3
                                class="text-center text-xs font-black mb-6 text-red-600 font-sans uppercase tracking-[0.3em]">
                                Historical Significance
                            </h3>
                            <p
                                class="text-stone-300 font-sans text-sm leading-relaxed italic text-center max-w-xl mx-auto">
                                Known for its strict discipline and architectural grandeur, the hostel has been a
                                crucial forge for academic excellence, cultural values, and the Indian freedom struggle.
                            </p>
                        </div>
                    </article>
                </div>

                <section class="max-w-7xl mx-auto px-6 mt-32">
                    <div class="mb-32 text-center max-w-3xl mx-auto">
                        <h2 class="text-4xl md:text-5xl tracking-tighter italic text-white mb-8">
                            Hall of <span class="text-red-600">Eminence</span>
                        </h2>
                        <div class="h-[1px] w-24 bg-red-800 mx-auto mb-8"></div>
                        <p class="text-zinc-500 font-sans text-base leading-relaxed italic">
                            From these corridors emerged the voices that drafted our constitution, the pens that moved
                            millions, and the minds that unlocked the secrets of the cosmos.
                        </p>
                    </div>

                    <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-8 space-y-8 pb-20">
                        <% if (scholars && scholars.length> 0) { %>
                            <% scholars.forEach(scholar=> { %>
                                <div
                                    class="break-inside-avoid bg-zinc-900/30 border border-zinc-800/50 p-10 rounded-3xl hover:border-red-900 hover:bg-zinc-900 transition-all duration-700 group relative shadow-2xl backdrop-blur-sm">

                                    <div class="flex justify-between items-start mb-8">
                                        <span
                                            class="bg-red-950/30 text-red-500 border border-red-900/50 px-3 py-1 rounded text-[9px] font-black font-sans uppercase tracking-widest">
                                            <%= scholar.tag %>
                                        </span>
                                        <span
                                            class="text-[10px] font-mono text-zinc-500 italic group-hover:text-yellow-600 transition-colors">
                                            <%= scholar.era %>
                                        </span>
                                    </div>

                                    <h3
                                        class="text-2xl font-bold text-zinc-100 mb-3 italic group-hover:text-white transition-colors">
                                        <%= scholar.name %>
                                    </h3>
                                    <p
                                        class="text-zinc-500 font-sans text-[11px] leading-relaxed uppercase tracking-wider group-hover:text-zinc-300 transition-colors">
                                        <%= scholar.role %>
                                    </p>

                                    <% if (locals.user && (user.role==='warden' || user.role==='admin' )) { %>
                                        <div
                                            class="mt-8 pt-6 border-t border-zinc-800/50 flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-all translate-y-2 group-hover:translate-y-0">
                                            <form action="/admin/scholars/delete/<%= scholar._id %>" method="POST"
                                                onsubmit="return confirm('Excise this record from the permanent archives?')">
                                                <button
                                                    class="text-red-800 text-[9px] font-black uppercase hover:text-red-500 transition-colors flex items-center gap-1">
                                                    <i class="ri-delete-bin-7-line"></i> Delete Record
                                                </button>
                                            </form>
                                        </div>
                                        <% } %>

                                            <div
                                                class="mt-8 h-[1px] w-8 bg-zinc-800 group-hover:w-full group-hover:bg-red-900 transition-all duration-1000">
                                            </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div
                                            class="col-span-full py-32 text-center border-2 border-dashed border-zinc-900 rounded-3xl">
                                            <i class="ri-book-open-line text-5xl text-zinc-800 mb-4 block"></i>
                                            <p
                                                class="text-zinc-600 italic font-sans uppercase text-[10px] tracking-[0.4em]">
                                                The archives are currently being digitized</p>
                                        </div>
                                        <% } %>
                    </div>
                    <p class="text-zinc-400 block text-center font-sans text-[9px] uppercase tracking-widest font-bold">
                        <i class="ri-shield-flash-line"></i> Records Maintained by the Admins
                    </p>

                    <% if (locals.user && (user.role==='warden' || user.role==='admin' )) { %>
                        <a href="/admin/scholars/new"
                            class="fixed bottom-10 right-10 bg-red-700 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(185,28,28,0.4)] hover:scale-110 hover:bg-red-600 transition-all z-50">
                            <i class="ri-add-line text-2xl"></i>
                        </a>
                        <% } %>

                </section>
            </main>

            <%- include('partials/footer') %>