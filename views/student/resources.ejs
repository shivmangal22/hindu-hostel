<%- include('../partials/head') %>
    <%- include('../partials/nav') %>
        <%- include('../partials/flash') %>

            <main class="min-h-screen bg-zinc-950 text-stone-50 pb-20 font-serif overflow-x-hidden">
                <header class="py-12 border-b border-zinc-600 relative overflow-hidden">
                    <div class="absolute inset-0 opacity-10 pointer-events-none">
                        <div class="absolute -top-24 -left-24 w-96 h-96 bg-blue-900 rounded-full blur-[120px]"></div>
                    </div>
                    <div class="absolute inset-0 opacity-20 pointer-events-none">
                        <div class="absolute -top-24 -right-24 w-96 h-96 bg-red-900 rounded-full blur-[120px]"></div>
                    </div>
                    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
                        <h1 class="text-4xl md:text-6xl tracking-tighter italic text-white mb-4">The Academic Vault</h1>
                        <p class="text-zinc-500 font-sans text-xs uppercase tracking-[0.3em] mb-4">Curated Study
                            Materials</p>

                        <div class="relative group font-sans max-w-xl mx-auto">
                            <i
                                class="ri-search-2-line absolute left-6 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-blue-500 transition-colors text-xl"></i>
                            <input type="text" id="subjectSearch" onkeyup="searchVault()"
                                placeholder="Filter by subject or keyword..."
                                class="w-full bg-zinc-950/80 border border-zinc-700 rounded-full py-5 pl-16 pr-8 text-white shadow-2xl focus:border-blue-600 focus:ring-4 focus:ring-blue-900/20 outline-none transition-all placeholder:text-zinc-600 backdrop-blur-md">
                        </div>
                    </div>
                </header>

                <div class="max-w-7xl mx-auto px-6 mt-16">
                    <div class="flex justify-between items-center mb-12">
                        <a href="javascript:void(0)" onclick="history.back()"
                            class="group text-zinc-500 hover:text-white transition-all text-[11px] font-sans font-bold uppercase tracking-[0.2em] flex items-center gap-2">
                            <i class="ri-arrow-left-line group-hover:-translate-x-1 transition-transform"></i>
                            <span>Back</span>
                        </a>

                        <div
                            class="hidden md:flex gap-6 text-[12px] font-bold font-sans uppercase tracking-widest text-zinc-600">
                            <span class="flex justify-center items-center gap-2"><i class="ri-book-3-line"></i>
                                Available Subjects: <span class="text-blue-500">
                                    <%= resources.length %>
                                </span>
                            </span>
                        </div>
                    </div>

                    <div class="max-w-7xl mx-auto px-6 mt-10">
                        <div id="vaultGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
                            <% if (resources && resources.length> 0) { %>
                                <% resources.forEach(res=> { %>
                                    <div class="subject-card flex flex-col bg-zinc-900/40 border border-zinc-800 p-6 rounded-2xl hover:border-blue-900/40 hover:bg-zinc-900 transition-all duration-300 group"
                                        data-subject="<%= res.subject.toLowerCase() %>">

                                        <div class="mb-5">
                                            <h3
                                                class="text-lg font-bold text-white italic tracking-tight group-hover:text-blue-400 transition-colors truncate">
                                                <%= res.subject %>
                                            </h3>
                                        </div>

                                        <div class="space-y-6 flex-grow">
                                            <% if(res.studyMaterial && res.studyMaterial.length> 0) { %>
                                                <div class="space-y-2">
                                                    <p
                                                        class="text-[8px] uppercase tracking-widest text-zinc-400 font-sans font-black">
                                                        Study Material</p>
                                                    <div class="flex flex-col gap-1.5">
                                                        <% res.studyMaterial.forEach((link, i)=> { %>
                                                            <a href="<%= link %>" target="_blank"
                                                                class="flex items-center justify-between p-2.5 rounded-lg bg-zinc-950/50 border border-zinc-800 text-zinc-400 hover:text-white hover:border-blue-500 transition-all text-[10px] font-sans">
                                                                <span>Link <%= i + 1 %></span>
                                                                <i class="ri-external-link-line text-xs opacity-50"></i>
                                                            </a>
                                                            <% }) %>
                                                    </div>
                                                </div>
                                                <% } %>

                                                    <div class="grid grid-cols-2 gap-3">
                                                        <% if(res.resources && res.resources.length> 0) { %>
                                                            <div class="space-y-2">
                                                                <p
                                                                    class="text-[8px] uppercase tracking-widest text-zinc-400 font-sans font-black">
                                                                    Reference</p>
                                                                <div class="flex flex-wrap gap-1.5">
                                                                    <% res.resources.forEach((link, i)=> { %>
                                                                        <a href="<%= link %>" target="_blank"
                                                                            class="w-full text-center py-2 rounded-lg bg-zinc-950 border border-zinc-800 text-[9px] font-bold text-zinc-500 hover:text-white hover:border-zinc-500 transition-all">
                                                                            Ref <%= i + 1 %>
                                                                        </a>
                                                                        <% }) %>
                                                                </div>
                                                            </div>
                                                            <% } %>

                                                                <% if(res.previousPapers && res.previousPapers.length>
                                                                    0) { %>
                                                                    <div class="space-y-2">
                                                                        <p
                                                                            class="text-[8px] uppercase tracking-widest text-zinc-400 font-sans font-black">
                                                                            PYQs</p>
                                                                        <div class="flex flex-wrap gap-1.5">
                                                                            <% res.previousPapers.forEach((link, i)=> {
                                                                                %>
                                                                                <a href="<%= link %>" target="_blank"
                                                                                    class="w-full text-center py-2 rounded-lg bg-zinc-950 border border-zinc-800 text-[9px] font-bold text-zinc-500 hover:text-emerald-500 hover:border-emerald-900 transition-all">
                                                                                    Set <%= i + 1 %>
                                                                                </a>
                                                                                <% }) %>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>
                                                    </div>
                                        </div>

                                        <% if (locals.user && (user.role==='warden' || user.role==='admin' )) { %>
                                            <div
                                                class="mt-4 pt-2 border-t border-zinc-800/50 flex justify-end gap-4 opacity-100 transition-opacity">
                                                <a href="/admin/resources/edit/<%= res._id %>">
                                                    <button
                                                        class="text-[10px] font-bold text-zinc-600 hover:text-red-500">
                                                        <i class="ri-pencil-line"></i> Edit</button>
                                                </a>
                                                <form action="/admin/resources/delete/<%= res._id %>" method="POST">
                                                    <button type="submit"
                                                        class="text-[10px] font-bold text-zinc-600 hover:text-red-500">Delete</button>
                                                </form>
                                            </div>
                                            <% } %>
                                    </div>
                                    <% }) %>
                                        <% } %>
                        </div>
                    </div>

                    <div id="noResults"
                        class="hidden col-span-full py-32 text-center bg-zinc-900/20 rounded-[3rem] border border-zinc-700">
                        <i class="ri-search-eye-line text-6xl text-zinc-400 mb-6 block"></i>
                        <p class="text-zinc-400 font-sans text-xs uppercase tracking-[0.4em]">Subject not found in
                            archives</p>
                    </div>
                </div>
            </main>
            <% if (locals.user && (user.role==='warden' || user.role==='admin' )) { %>
                <div class="fixed bottom-8 right-8 z-50 group">
                    <span
                        class="absolute right-16 top-1/2 -translate-y-1/2 bg-blue-600 text-white text-[10px] font-bold px-3 py-1.5 rounded-lg tracking-widest opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap pointer-events-none shadow-xl">
                        ADD NEW SUBJECT
                    </span>

                    <a href="/admin/resources/new"
                        class="flex items-center justify-center w-14 h-14 bg-blue-700 text-white rounded-full shadow-[0_0_20px_rgba(29,78,216,0.4)] hover:shadow-[0_0_30px_rgba(29,78,216,0.6)] hover:scale-110 active:scale-95 transition-all duration-300">
                        <i class="ri-add-line text-3xl"></i>
                    </a>
                </div>
                <% } %>
                    <script>
                        function searchVault() {
                            const query = document.getElementById('subjectSearch').value.toLowerCase();
                            const cards = document.querySelectorAll('.subject-card');
                            let found = 0;

                            cards.forEach(card => {
                                const subject = card.getAttribute('data-subject');
                                if (subject.includes(query)) {
                                    card.style.display = "flex";
                                    found++;
                                } else {
                                    card.style.display = "none";
                                }
                            });
                            document.getElementById('noResults').style.display = found === 0 && query !== "" ? "block" : "none";
                        }
                    </script>

                    <%- include('../partials/footer') %>